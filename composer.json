{
  "name": "langleyfoxall/helpers-laravel",
  "description": "A collection of useful classes to help making Laravel applications easier",
  "prefer-stable": true,
  "type": "library",
  "license": "LGPL-3.0-only",
  "keywords": [
    "helpers",
    "php",
    "laravel"
  ],
  "homepage": "https://github.com/LFSoftware/helpers-laravel",
  "support": {
    "issues": "https://github.com/LFSoftware/helpers-laravel/issues",
    "source": "https://github.com/LFSoftware/helpers-laravel"
  },
  "authors": [
    {
      "name": "Dexter Marks-Barber",
      "email": "dexter@langleyfoxall.co.uk",
      "role": "Maintainer"
    },
    {
      "name": "Jordan Hall",
      "email": "jordan@langleyfoxall.co.uk",
      "role": "Maintainer"
    },
    {
      "name": "Jared Wheatley",
      "email": "jared@langleyfoxall.co.uk",
      "role": "Reviewer"
    }
  ],
  "require": {
    "php": "^8.3",
    "ext-mbstring": "*",
    "illuminate/support": "^12.0 || ^13.0",
    "illuminate/database": "^12.0 || ^13.0",
    "illuminate/http": "^12.0 || ^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0 || ^11.0"
  },
  "scripts": {
    "test": "phpunit"
  },
  "autoload": {
    "psr-4": {
      "LangleyFoxall\\": "src/LangleyFoxall/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LangleyFoxall\\": "tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "1.x-dev"
    }
  }
}
